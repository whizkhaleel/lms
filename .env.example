# Root environment template.
# Copy this file to .env locally and replace placeholder values.
# This template is safe to commit. Do not commit real secrets.

# Environment
NODE_ENV=development
APP_ENV=local
APP_NAME=Shaheed Mahmoud Academy
APP_URL=http://localhost:8080

# Backend
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
API_URL=http://localhost:5000

# Frontend
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:5000

# Database
POSTGRES_DB=lms
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=lms
DB_USER=lms_user
DB_PASSWORD=change_me
DATABASE_URL=postgresql://lms_user:change_me@localhost:5433/lms

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_URL=redis://:change_me@redis:6379

# MinIO / S3-compatible storage
MINIO_ACCESS_KEY=lms_minio
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=lms-files

# Authentication
JWT_ACCESS_SECRET=change_me_to_a_long_random_access_secret
JWT_REFRESH_SECRET=change_me_to_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File storage
STORAGE_BACKEND=local
LMSDATA_PATH=/app/lmsdata
UPLOADS_DIR=./lmsdata/uploads
CERTIFICATES_DIR=./lmsdata/certificates
TEMP_DIR=./lmsdata/temp
PRIVATE_DIR=./lmsdata/private

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Docker / Nginx
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
