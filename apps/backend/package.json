{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "LMS Platform — Node.js Express API",
  "main": "server.js",
  "scripts": {
    "start":            "node server.js",
    "dev":              "nodemon server.js",
    "test":             "node --test tests/unit/*.test.js && node test.js",
    "test:unit":        "node --test tests/unit/*.test.js",
    "test:integration": "node test.js",
    "test:coverage":    "node --test tests/unit/*.test.js && node test.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": [
      "modules/**/*.js",
      "shared/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageReporters": ["text", "lcov"],
    "testTimeout": 15000
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "bullmq": "^5.1.1",
    "nodemailer": "^6.9.8",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "file-type": "^18.7.0",
    "socket.io": "^4.6.2",
    "minio": "^7.1.3",
    "slugify": "^1.6.6",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "nodemon": "^3.0.3"
  }
}