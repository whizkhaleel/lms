{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "Shaheed Mahmoud Academy — Node.js Express API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test tests/unit/*.test.js && node test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node test.js",
    "db:reset": "node scripts/reset-db.js",
    "test:coverage": "node --test tests/unit/*.test.js && node test.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "modules/**/*.js",
      "shared/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 15000
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "file-type": "^18.7.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^7.1.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "slugify": "^1.6.6",
    "socket.io": "^4.6.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  }
}
